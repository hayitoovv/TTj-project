# ============================================================
# TTJ Platforma — PRODUCTION env (.env on the VPS)
# Copy: cp .env.production.example .env
# Then edit values below.
# ============================================================

# --- General ---
APP_NAME=TTJ Platforma
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=https://ttj.zarmeduniver.com

# --- Security ---
# IMPORTANT: generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- PostgreSQL ---
POSTGRES_USER=ttj_user
# IMPORTANT: choose a strong password (16+ random chars)
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=ttj_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ttj_user:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/ttj_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- SMS (Eskiz.uz) ---
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# --- HEMIS (kelajakda) ---
HEMIS_API_URL=https://student.hemis.uz/rest/v1
HEMIS_API_TOKEN=

# --- Payment gateways (kelajakda) ---
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

PAYNET_MERCHANT_ID=
PAYNET_SECRET_KEY=

# --- Frontend (build-time) ---
NEXT_PUBLIC_API_URL=https://ttj.zarmeduniver.com/api/v1
