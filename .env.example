# ===========================================
# TTJ PLATFORMA — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- General ---
APP_NAME=TTJ Platforma
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- PostgreSQL ---
POSTGRES_USER=ttj_user
POSTGRES_PASSWORD=ttj_password_change_me
POSTGRES_DB=ttj_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ttj_user:ttj_password_change_me@postgres:5432/ttj_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- SMS (Eskiz.uz) ---
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# --- HEMIS ---
HEMIS_API_URL=https://student.hemis.uz/rest/v1
HEMIS_API_TOKEN=

# --- Payment gateways ---
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

UZUM_MERCHANT_ID=
UZUM_SECRET_KEY=

PAYNET_MERCHANT_ID=
PAYNET_SECRET_KEY=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- File storage (S3-compatible: Cloudflare R2 / MinIO) ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=ttj-uploads
S3_REGION=auto
